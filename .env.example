# Copy this file to .env and fill in your values.
# Never commit .env to git — it's in .gitignore.

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Perplexity Sonar ---
PERPLEXITY_API_KEY=pplx-...

# --- API-Football (free tier: 100 req/day) ---
API_FOOTBALL_KEY=...

# --- Gmail SMTP (App Password — no Google Cloud Console needed) ---
# 1. Create a Gmail account (dedicated one recommended, e.g. stryktipset.tips@gmail.com)
# 2. Enable 2-Step Verification: myaccount.google.com → Security
# 3. Generate App Password: Security → App Passwords → Mail → Generate
# 4. Paste the 16-char code below (spaces are fine, they're ignored)
GMAIL_SENDER=stryktipset.tips@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Newsletter recipients (comma-separated) ---
NEWSLETTER_RECIPIENTS=you@gmail.com,friend@gmail.com

# --- Scheduler (only used when running locally, not on GitHub Actions) ---
SCHEDULE_DAY=sat
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0
SCHEDULE_TIMEZONE=Europe/Stockholm

# --- Models ---
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=8192
PERPLEXITY_MODEL=sonar

# --- Cache TTL (seconds) — default 7 days ---
CACHE_TTL_SECONDS=604800
